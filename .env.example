# ─────────────────────────────────────────────────────────────────────────
# Sanity write token — used ONLY by the one-time migration script
# (scripts/migrate-to-sanity.mjs). It is a SECRET: never commit the real .env.
#
# How to get it:
#   1. Go to https://www.sanity.io/manage  →  your project
#   2. API  →  Tokens  →  Add API token
#   3. Name: "migration",  Permission: Editor
#   4. Copy this file to a new file named ".env" and paste the token below.
# ─────────────────────────────────────────────────────────────────────────
SANITY_API_TOKEN=

# These are not secrets; defaults are already baked into the app.
SANITY_PROJECT_ID=8a36ilal
SANITY_DATASET=production
